<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/common_item_root"
    style="@style/AppCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal">

    <ImageView
        android:id="@+id/common_item_icon"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:src="@drawable/ic_settings" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="14dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/common_item_title"
            style="@style/AppText.Title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="标题" />

        <TextView
            android:id="@+id/common_item_subtitle"
            style="@style/AppText.Subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="1dp"
            android:text="描述信息" />
    </LinearLayout>

    <ImageView
        android:id="@+id/common_item_arrow"
        android:layout_width="18dp"
        android:layout_height="18dp"
        android:alpha="0.3"
        android:rotation="180"
        android:src="@drawable/ic_arrow_back" />
</LinearLayout>
